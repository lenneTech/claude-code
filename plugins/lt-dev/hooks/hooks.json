{
  "description": "Project detection, safety guards, circuit breaker, file protection, and lt-plugin auto-update",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/update-lt-plugins.sh\"",
            "timeout": 5,
            "statusMessage": "Checking lt CLI plugin updates"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/validate-plugin-frontmatter.sh\"",
            "timeout": 5,
            "statusMessage": "Validating plugin frontmatter"
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/protect-files.sh\"",
            "timeout": 3,
            "statusMessage": "Checking file protection"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/block-dangerous-bash.sh\"",
            "timeout": 5,
            "statusMessage": "Checking for dangerous commands"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/circuit-breaker-reset.sh\"",
            "timeout": 3
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/circuit-breaker.sh\"",
            "timeout": 3,
            "statusMessage": "Checking circuit breaker"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/detect-nuxt.sh\"",
            "timeout": 5,
            "statusMessage": "Detecting project context"
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/detect-nest-server.sh\"",
            "timeout": 5,
            "statusMessage": "Detecting project context"
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/detect-lt-cli.sh\"",
            "timeout": 5,
            "statusMessage": "Detecting project context"
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/detect-plugin-dev.sh\"",
            "timeout": 5,
            "statusMessage": "Detecting project context"
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/detect-security-context.sh\"",
            "timeout": 5,
            "statusMessage": "Detecting project context"
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/detect-npm-maintenance.sh\"",
            "timeout": 5,
            "statusMessage": "Detecting project context"
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "rm -f /tmp/.claude-circuit-breaker/* 2>/dev/null; true"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/post-compact-context.sh\"",
            "timeout": 5,
            "statusMessage": "Re-injecting project context"
          }
        ]
      }
    ]
  }
}
